APP_NAME="OpcionYo QA Case"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database -------------------------------------------------------------
# SQLite keeps the sample zero-dependency. Switch to mysql to mirror prod.
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite   # defaults to database/database.sqlite

# --- Drivers kept simple so nothing external is required ------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=file
MAIL_MAILER=log

# --- Stripe (Flow B) ------------------------------------------------------
# Create a free account at https://dashboard.stripe.com and stay in TEST mode.
# The mocked test suite runs without real keys; the opt-in sandbox test and
# local webhook forwarding need these filled in.
STRIPE_KEY=pk_test_xxx
STRIPE_SECRET=sk_test_xxx
# `stripe listen` prints this when you start it (whsec_...).
STRIPE_WEBHOOK_SECRET=whsec_test_secret_for_signing

# --- AWS Chime (Flow: video calls) ----------------------------------------
# Not required for the test suite (the Chime SDK is mocked). Fill in only if
# you want to hit real Chime from tinker/manual checks.
CHIME_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
