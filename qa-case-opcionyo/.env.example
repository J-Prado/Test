APP_NAME=OpcionYo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database (MySQL, as per the document) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=opcionyo
DB_USERNAME=root
DB_PASSWORD=

# Drivers that don't need extra services during local dev.
SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Stripe (Flow B) — use sandbox/test keys ---
# Leave STRIPE_SECRET empty to run in fake mode (recognizes Stripe test cards,
# auto-confirms after STRIPE_AUTO_CONFIRM_MS). Fill it to hit real sandbox.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_AUTO_CONFIRM_MS=1500

# --- AWS Chime (video) ---
CHIME_ENABLED=false
CHIME_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

VITE_APP_NAME="${APP_NAME}"
